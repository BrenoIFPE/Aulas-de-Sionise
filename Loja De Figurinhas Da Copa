def comprar_figurinha ():
    global estoque_pacotes

    print ("Comprar Pacote De Figurinhas")
    print ("O Pacote Custa R$ 7,00")

    quantidade = int(input("Quantos Pacotes Você Deseja ? "))

    if quantidade <= estoque_pacotes:

        valor_total = quantidade * preco_pacote

        estoque_pacotes -= quantidade

        print (f"{quantidade} Pacotes De Figurinhas Foram Adicionados")
        print (f"Valor Total R$ {valor_total}")

    else:

        print ("Desculpe Não Temos Essa Quantidade")

        if estoque_pacotes > 0:

            valor_total = estoque_pacotes * preco_pacote

            print (f"Só {estoque_pacotes} Pacotes Foram Adicionados")
            print ("Não Temos Mais Em Estoque")
            print (f"Valor Total R$ {valor_total}")

            estoque_pacotes = 0

        else:
            print ("Produto Sem Estoque")


