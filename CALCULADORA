#CALCULADORA

print("BEM-VINDO A CALCULADORA!!")
print("digite adição pra somar")
print("digite subtração pra subtrair")
print("digite multiplicação pra multiplicar")
print("digite divisão pra dividir")
print("digite potencia para potenciação")
print("digite raiz para radiciação")
print("digite porcentagem pra porcentagem")
print("digite 'sair' se quiser sair da calculadora")

operacao = []
while True:
    op = input("Digite A Operação Que Você Deseja Resolver: ").lower()
    if op == "adição":
        n1 = float(input("Digite O Primeiro Número: "))
        n2 = float(input("Digite O Segundo Número: "))
        calculo1 = n1 + n2 
        operacao.append(calculo1)
        print(f"O Resultado Da Sua Soma Deu {calculo1}")
    elif op == "subtração":
        n3 = float(input("Digite O Primeiro Número: "))
        n4 = float(input("Digite O Primeiro Número: "))
        calculo2 = n3 - n4
        operacao.append(calculo2)
        print(f"O Resultado Da Sua Subtração Deu {calculo2}")
    elif op == "multiplicação":
        n5 = float(input("Digite O primeiro Número: "))
        n6 = float(input("Digite O Segundo Número: "))
        calculo3 = n5 * n6
        operacao.append(calculo3)
        print(f"O Resultado Da Sua Multiplicação Deu {calculo3}")
    elif op == "divisão":
        n7 = float(input("Digite O Primeiro Número: "))
        n8 = float(input("Digite O Segundo Número: "))
        calculo4 = n7 / n8 
        operacao.append(calculo4)
        print(f"O Resultado Da Sua Divisão Foi De {calculo4}")
    elif op == "potencia":
        n9 = float(input("Digite O Primeiro Número: "))
        n10 = float(input("Digite O Segundo Número: "))
        calculo5 = n9 ** n10
        operacao.append(calculo5)
        print(f"O Resultado Da Sua Pontencia Foi De {calculo5}")
    elif op == "raiz":
        n11 = float(input("Digite O Primeiro Número: "))
        calculo6 = n11 ** 0.5
        operacao.append(calculo6)
        print(f"O Resultado Da Sua Raiz Foi De {calculo6}")
    elif op == "porcentagem":
        n12 = float(input("Digite O Primeiro Número: "))
        n13 = float(input("Digite O Segundo Número: "))
        calculo7 = n12 * n13 / 100
        operacao.append(calculo7)
        print(f"O Resultado Da Sua Porcentagem Foi De {calculo7}")
    elif op == "sair":
        print("Fechando A Calculadora")
        print(operacao)
        break
